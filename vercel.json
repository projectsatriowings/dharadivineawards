{
  "redirects": [
    {
      "source": "/admin",
      "destination": "https://dhara-admin-bice.vercel.app",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "https://dhara-admin-bice.vercel.app/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dhara-admin-bice.vercel.app/api/:path*"
    },
    {
      "source": "/((?!api|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
